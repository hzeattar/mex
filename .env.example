# VertexPluse Trading Platform — example env
# Copy to .env and then replace secrets / tokens / emails with your real values.

# --- App / bootstrap ---
APP_ENV=production
APP_DEBUG=0
APP_URL=https://your-domain.example
SITE_URL=https://your-domain.example
APP_KEY=base64:CHANGE_ME_32CHARS_MIN
AUTO_MIGRATE=0
LOG_ENABLED=1
LOG_LEVEL=WARN
LOG_MAX_BYTES=4194304

# --- Auth / security ---
JWT_SECRET=change_me_jwt_secret
CRON_KEY=change_me_cron_key
INSTALL_KEY=change_me_install_key
DEBUG_KEY=change_me_debug_key
MASTER_KEY=change_me_master_key
BOT_API_TOKEN=change_me_bot_api_token
BOT_INTENT_SECRET=change_me_bot_intent_secret
PAYMENT_WEBHOOK_SECRET=change_me_payment_webhook_secret
SIGNAL_WEBHOOK_SECRET=change_me_signal_webhook_secret
CRYPTO_PAY_WEBHOOK_SECRET=change_me_cryptopay_webhook_secret

# --- Stripe card checkout (optional, production secrets live in Railway variables only) ---
STRIPE_ENABLED=0
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# --- Database (MySQL recommended) ---
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vertexpluse
DB_USER=vertexpluse_user
DB_PASS=change_me
DB_SQLITE_PATH=./api/data/app.sqlite
DB_BUSY_TIMEOUT=8
DB_CONNECT_TIMEOUT=5
DB_PERSISTENT=0
DB_USE_PUBLIC_PROXY=auto
DB_ALLOW_SQLITE_FALLBACK=0
AUTH_BOOTSTRAP_SCHEMA=0
AUTH_BOOTSTRAP_ON_MISSING=1

# --- One-time MySQL import guard ---
ALLOW_SQL_IMPORT=0
ALLOW_SQL_DANGEROUS=0
SQL_IMPORT_MAX_BYTES=67108864

# --- Web-first auth mode ---
ALLOW_GUEST=1
REQUIRE_TG_INITDATA=0
TG_INITDATA_MAX_AGE=86400
ALLOW_REAL_TO_DEMO=0

# --- Brand / currencies / accounts ---
DEFAULT_CURRENCY=USD
REAL_CURRENCY=USDT
SUPPORTED_CURRENCIES=USD,EUR,USDT
DEMO_CURRENCY=USDT_DEMO
DEMO_START_BALANCE=10000

# --- Admin ---
ADMIN_EMAIL=admin@your-domain.example
ADMIN_PASSWORD=ChangeThisAdminPassword

# --- Market data providers ---
PRICE_PROVIDER=yahoo
CRYPTO_PROVIDER=binance
PAID_QUOTES_PROVIDER=none
PAID_QUOTES_API_KEY=
QUOTES_TWELVEDATA_KEY=
TWELVEDATA_ENABLED=1
TWELVEDATA_PRICE_TTL=5
TWELVEDATA_CANDLES_TTL=60
TWELVEDATA_CANDLES_MAX_OUTPUTSIZE=5000
FINNHUB_KEY=
FINNHUB_ENABLED=1
FINNHUB_PRICE_TTL=5
TIINGO_KEY=
TIINGO_ENABLED=1
TIINGO_PRICE_TTL=5
POLYGON_API_KEY=
POLYGON_API_BASE=https://api.massive.com
EODHD_API_KEY=
EODHD_API_BASE=https://eodhd.com/api
MASSIVE_AUTH_MODE=bearer
MASSIVE_AGGS_ONLY=1
UPSTREAM_RATE_PER_SEC=8
UPSTREAM_BURST=16
UPSTREAM_RETRIES=1
UPSTREAM_CONNECT_TIMEOUT=3
UPSTREAM_TIMEOUT=5
UPSTREAM_FORBIDDEN_TTL=21600

# --- Market cache / quote tuning ---
MASSIVE_SNAPSHOT_TTL=2
MASSIVE_FOREX_TTL=1
MASSIVE_STOCKS_TTL=4
MASSIVE_COMMODITIES_TTL=2
NONCRYPTO_PRICE_TTL=2
POLYGON_PRICE_TTL=4
YAHOO_PRICE_TTL=3
YAHOO_PRICE_TTL_FRESH=1
YAHOO_ALLOW_CHART_QUOTE_FALLBACK=1
YAHOO_ENABLED=1
FRANKFURTER_ENABLED=1
FRANKFURTER_PRICE_TTL=3600
MASSIVE_SNAPSHOT_TTL_FRESH=1
EODHD_PRICE_TTL=2
QUOTES_API_FRESH_CACHE_TTL_CRYPTO=1
QUOTES_API_FRESH_CACHE_TTL_NONCRYPTO=1
MARKETS_STALE_SECONDS=5
COMMODITIES_STALE_SECONDS=3
CRYPTO_PRICE_TTL=1
CRYPTO_QUOTE_TTL=1
CRYPTO_CHANGE_TTL=10
CRYPTO_CHG_TTL=10
CRYPTO_STALE_SECONDS=2
NONCRYPTO_STALE_SECONDS=3
QUOTE_STALE_SECONDS=300
QUOTES_API_CACHE_TTL_CRYPTO=1
QUOTES_API_CACHE_TTL_FOREX=1
QUOTES_API_CACHE_TTL_ARAB=1
QUOTES_API_CACHE_TTL_STOCKS=1
QUOTES_API_CACHE_TTL_COMMODITIES=2
QUOTES_API_STALE_CACHE_TTL_NONCRYPTO=1
QUOTES_TICK_BUDGET_SEC=18
QUOTES_TICK_MAX_MARKETS=1200
QUOTES_TICK_MAX_EXEC=20
NONCRYPTO_EXTERNAL_BATCH=24
NONCRYPTO_SIMULATE=0
READ_ENDPOINTS_PERSIST_QUOTES=0
COUNTRY_CURRENCY_TTL=2592000
FX_TTL=1800
FX_OVERRIDE_IQD=

# --- Market / chart runtime ---
MARKETS_FIRST_BATCH_SIZE=10
MARKETS_BATCH_SIZE=16
MARKETS_CACHE_TTL=2
MARKETS_CACHE_TTL_QUOTES=1
MARKETS_CACHE_TTL_LIVE_NONCRYPTO=1
MARKETS_REFRESH_GUARD_TTL=1
MARKET_TICKS_KEEP_SEC=1209600
CANDLES_AUTH_MAX_LIMIT=12000
CANDLES_MAX_STALE_FAST=120
CANDLES_REFRESH_GUARD_TTL=2
STREAM_SPOT_TTL=1
STREAM_PERP_TTL=1
STREAM_LITE_CACHE_TTL=1
STREAM_LITE_STALE_CACHE_TTL_NONCRYPTO=1
STREAM_REFRESH_BUDGET=12
SSE_ALLOW_WATCHLIST_LIVE=0
DEPTH_TTL=8
ENTRY_QUOTE_MAX_AGE=3
ENTRY_QUOTE_MAX_AGE_CRYPTO=10
ENTRY_QUOTE_MAX_AGE_FOREX=1800
ENTRY_QUOTE_MAX_AGE_COMMODITIES=3600
ENTRY_QUOTE_MAX_AGE_FUTURES=3600
ENTRY_QUOTE_MAX_AGE_STOCKS=21600
ENTRY_QUOTE_MAX_AGE_ARAB=21600

# --- Trading / risk / fees ---
PERP_QUOTES_ENABLED=1
PERP_MAX_SYMBOLS=3
PERP_MARK_TTL=1
PERP_QUOTE_TTL=1
PERP_MAX_LEVERAGE=125
PERP_MAINTENANCE_MARGIN_RATE=0.005
TRADING_FEES_ENABLED=0
SPOT_MAKER_FEE=0.0002
SPOT_TAKER_FEE=0.0004
PERP_MAKER_FEE=0.0002
PERP_TAKER_FEE=0.0004

# --- Main bot / Telegram login (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
MINIAPP_BOT_USERNAME=
BOT_ADMIN_CHAT_IDS=
BOT_PATH_TOKEN=change_me_bot_path_token
BOT_WEBHOOK_KEY=change_me_bot_webhook_key
BOT_WEBHOOK_SECRET=change_me_bot_webhook_secret

# --- Legacy pay bot compatibility (keep blank unless you still use it) ---
BOT_TOKEN=
BOT_USERNAME=
PAY_BOT_USERNAME=
CRYPTO_PAY_API_TOKEN=
CRYPTO_PAY_BASE=https://pay.crypt.bot
CRYPTO_PAY_EXPIRES_IN=1800

# --- Support bot / support channels (optional) ---
SUPPORT_BOT_TOKEN=
SUPPORT_BOT_USERNAME=
SUPPORT_BOT_PATH_TOKEN=change_me_support_bot_path_token
SUPPORT_BOT_WEBHOOK_KEY=change_me_support_bot_webhook_key
SUPPORT_BOT_WEBHOOK_SECRET=change_me_support_bot_webhook_secret
SUPPORT_IN_MAIN_BOT=0
SUPPORT_CONTACT_EN=
SUPPORT_CONTACT_AR=
SUPPORT_CONTACT_RU=

# --- Affiliate / managers bot (optional) ---
AFF_BOT_TOKEN=
AFF_BOT_PATH_TOKEN=change_me_aff_bot_path_token
AFF_BOT_WEBHOOK_KEY=change_me_aff_bot_webhook_key
AFF_BOT_WEBHOOK_SECRET=change_me_aff_bot_webhook_secret
AFF_ADMIN_CHAT_IDS=
AFF_ADMIN_LANG=ar
AFF_NOTIFY_ENABLED=1
CLIENT_BOT_USERNAME=

# --- Uploads / runtime ---
MAX_UPLOAD_SIZE=6M
UPLOAD_PATH=./api/uploads
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

QUOTES_API_DIRECT_CACHE_TTL_NONCRYPTO=0

QUOTES_API_VISIBLE_CACHE_TTL_NONCRYPTO=0
ENABLE_MASSIVE_FALLBACK=0
STOCK_QUOTES_PROVIDER=yahoo
ARAB_QUOTES_PROVIDER=yahoo
