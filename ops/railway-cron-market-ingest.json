{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "php api/cron/market_ingest.php --token=$CRON_KEY",
    "restartPolicyType": "ALWAYS",
    "healthcheckTimeout": 30
  },
  "cron": {
    "schedule": "*/5 * * * *",
    "timezone": "UTC"
  }
}